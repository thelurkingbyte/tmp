#!/bin/sh
set -eu

ANDROID_DIR="$HOME/Android"
WAYDROID_MEDIA="$HOME/.local/share/waydroid/data/media/0"

start() {
    mkdir -p "$ANDROID_DIR"

    echo "Starting Waydroid..."
    waydroid session start >/dev/null 2>&1 &

    echo "Waiting for Waydroid..."
    until sudo waydroid shell true >/dev/null 2>&1; do
        sleep 1
    done

    if ! mountpoint -q "$ANDROID_DIR"; then
        echo "Mounting internal storage..."
        sudo mount --bind "$WAYDROID_MEDIA" "$ANDROID_DIR"
    fi

    echo "Waydroid is ready."
}

stop() {
    if mountpoint -q "$ANDROID_DIR"; then
        echo "Unmounting internal storage..."
        sudo umount "$ANDROID_DIR"
    fi

    echo "Stopping Waydroid..."
    waydroid session stop

    echo "Done."
}

status() {
    echo "Waydroid:"
    sudo waydroid status || true
    echo

    echo "Mount:"
    if mountpoint -q "$ANDROID_DIR"; then
        echo "Mounted at $ANDROID_DIR"
    else
        echo "Not mounted"
    fi
}

case "${1:-}" in
    start)
        start
        ;;
    stop)
        stop
        ;;
    restart)
        stop
        start
        ;;
    status)
        status
        ;;
    *)
        echo "Usage: android {start|stop|restart|status}"
        exit 1
        ;;
esac
